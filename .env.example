TELEGRAM_BOT_TOKEN=
ALLOWED_TELEGRAM_USER_IDS=

DASHBOARD_ADMIN_USERNAME=admin
# Set this before first dashboard run. If left empty, a one-time random password is saved in data/dashboard_admin_bootstrap.txt.
DASHBOARD_ADMIN_PASSWORD=

OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.2:latest
OLLAMA_FALLBACK_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large:latest

DATA_DIR=data
CHROMA_DIR=workspace/chroma
UPLOADS_DIR=workspace/uploads
GENERATED_DIR=workspace/generated
STRUCTURED_DIR=workspace/structured

WHISPER_MODEL=base

# Keep false for fully local operation. Set true to allow Pollinations image fallback.
ALLOW_IMAGE_EXTERNAL_FALLBACK=false
STABLE_DIFFUSION_MODEL=

# Optional external web search/scraping via Tavily.
# Keep disabled for fully local/private operation.
ALLOW_WEB_SEARCH=false
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
